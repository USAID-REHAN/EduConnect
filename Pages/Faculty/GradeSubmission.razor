@* GradeSubmission.razor — /faculty/grades *@
@namespace EduConnect.Pages
@* Two-way binding on course dropdown; EventCallback OnCourseSelected loads students *@
@* Inline-editable marks table with IValidatable *@

@page "/faculty/grades"
@inject ICourseService CourseSvc
@inject IStudentService StudentSvc
@inject IGradeService GradeSvc
@inject AuthStateService Auth

<AuthGuard RequiredRole="UserRole.Faculty">
<div class="ec-page">
    <div class="ec-page-header">
        <div>
            <h1 class="ec-page-title">Grade Submission</h1>
            <p class="ec-page-subtitle">Select a course, enter marks, and submit</p>
        </div>
    </div>

    <AlertBox Message="@_successMsg" Type="AlertType.Success" />
    <AlertBox Message="@_errorMsg"   Type="AlertType.Error" />

    <div class="ec-card mb-4" style="max-width:400px">
        <div class="ec-card-header"><h5>Select Course</h5></div>
        <div class="ec-card-body">
            @* Two-way binding on course dropdown *@
            <select class="ec-select" @bind="_selectedCourseId" @bind:after="OnCourseSelected">
                <option value="">-- Choose a course --</option>
                @foreach (var c in MyCourses)
                {
                    <option value="@c.Id">@c.Code — @c.Title</option>
                }
            </select>
        </div>
    </div>

    @if (_selectedCourse is not null)
    {
        <div class="ec-card">
            <div class="ec-card-header">
                <h5>@_selectedCourse.Code — Students (@_gradeRows.Count)</h5>
            </div>
            <div class="ec-card-body">
                @if (!_gradeRows.Any())
                {
                    <p style="color:var(--text-muted)">No students enrolled in this course.</p>
                }
                else
                {
                    <div style="overflow:auto">
                        <table class="ec-table">
                            <thead><tr><th>Student</th><th>Marks (0–100)</th><th>Grade</th></tr></thead>
                            <tbody>
                                @foreach (var row in _gradeRows)
                                {
                                    <tr class="@row.Record.RowCssClass">
                                        <td style="font-weight:500">@row.StudentName</td>
                                        <td>
                                            @* Two-way binding on inline marks input *@
                                            <input class="ec-input @(row.Error ? "is-invalid" : "")"
                                                   style="width:100px" type="number" min="0" max="100"
                                                   @bind="row.Record.Marks" @bind:event="oninput" />
                                            @if (row.Error)
                                            { <span class="ec-error-msg">0–100 only</span> }
                                        </td>
                                        <td style="font-weight:700">@(row.Record.Marks >= 0 ? row.Record.LetterGrade : "—")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div style="margin-top:1.25rem;display:flex;justify-content:flex-end">
                        <button class="ec-btn ec-btn-primary" @onclick="SubmitGrades">Submit All Grades</button>
                    </div>
                }
            </div>
        </div>
    }
</div>
</AuthGuard>

@code {
    // Helper to hold student name alongside their grade record row
    record GradeRow(GradeRecord Record, string StudentName) { public bool Error { get; set; } }

    Guid          _selectedCourseId;
    Course?       _selectedCourse;
    List<GradeRow> _gradeRows = new();
    string        _successMsg = string.Empty;
    string        _errorMsg   = string.Empty;

    List<Course> MyCourses => Auth.CurrentUser is Faculty f
        ? CourseSvc.GetFacultyCourses(f.Id) : new();

    // Fired when course dropdown changes — EventCallback pattern
    void OnCourseSelected()
    {
        _successMsg = _errorMsg = string.Empty;
        _selectedCourse = _selectedCourseId == Guid.Empty ? null
            : CourseSvc.GetById(_selectedCourseId);

        if (_selectedCourse is null) { _gradeRows = new(); return; }

        // Load enrolled students and build grade rows
        var activeEnrollments = _selectedCourse.Enrollments
            .Where(e => e.State == EnrollmentState.Active).ToList();

        _gradeRows = activeEnrollments.Select(e =>
        {
            var stu     = StudentSvc.GetById(e.StudentId);
            var existing = GradeSvc.GetGradesForCourse(_selectedCourse.Id)
                               .FirstOrDefault(g => g.StudentId == e.StudentId);
            var rec = existing ?? new GradeRecord
            {
                StudentId   = e.StudentId,
                CourseId    = _selectedCourse.Id,
                CreditHours = _selectedCourse.CreditHours,
                Marks       = -1
            };
            return new GradeRow(rec, stu?.FullName ?? "Unknown");
        }).ToList();
    }

    void SubmitGrades()
    {
        // Validate each row using IValidatable
        bool hasError = false;
        foreach (var row in _gradeRows)
        {
            var errors = row.Record.Validate();
            row.Error = errors.Any();
            if (row.Error) hasError = true;
        }
        if (hasError) { _errorMsg = "Fix validation errors before submitting."; return; }

        foreach (var row in _gradeRows)
            GradeSvc.SubmitGrade(row.Record); // fires OnGradesSubmitted notification

        _successMsg = $"Grades submitted for {_gradeRows.Count} students.";
        _errorMsg   = string.Empty;
    }
}
