@* LoadingSpinner.razor — wraps async operations *@
@* Accepts IsLoading (bool) — shows spinner or child content *@

@if (IsLoading)
{
    <div class="ec-spinner-wrap">
        <div class="ec-spinner"></div>
        <span>Loading...</span>
    </div>
}
else
{
    @ChildContent
}

@code {
    [Parameter] public bool IsLoading       { get; set; } = false;
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
